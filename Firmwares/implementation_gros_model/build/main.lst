 447:Core/Src/main.c **** static void LoRa_SendATAndPrintResponse(const char *label, const uint8_t *cmd, uint16_t cmd_len,
 448:Core/Src/main.c ****                                         uint32_t response_window_ms, uint32_t post_cmd_delay_ms)
 449:Core/Src/main.c **** {
 450:Core/Src/main.c ****   uint8_t rx_byte = 0U;
 451:Core/Src/main.c ****   char response[128];
 452:Core/Src/main.c ****   uint32_t response_len = 0U;
 453:Core/Src/main.c ****   uint32_t start = 0U;
 454:Core/Src/main.c ****   uint32_t last_rx_tick = 0U;
 455:Core/Src/main.c **** 
 456:Core/Src/main.c ****   (void)HAL_UART_Transmit(&hlpuart1, (uint8_t *)cmd, cmd_len, HAL_MAX_DELAY);
 457:Core/Src/main.c **** 
 458:Core/Src/main.c ****   start = HAL_GetTick();
 459:Core/Src/main.c ****   last_rx_tick = start;
 460:Core/Src/main.c **** 
 461:Core/Src/main.c ****   while ((HAL_GetTick() - start) < response_window_ms)
 462:Core/Src/main.c ****   {
ARM GAS  /tmp/ccfoQJXi.s 			page 11


 463:Core/Src/main.c ****     if (HAL_UART_Receive(&hlpuart1, &rx_byte, 1U, 20U) == HAL_OK)
 464:Core/Src/main.c ****     {
 465:Core/Src/main.c ****       if (response_len < (sizeof(response) - 1U))
 466:Core/Src/main.c ****       {
 467:Core/Src/main.c ****         response[response_len++] = (char)rx_byte;
 468:Core/Src/main.c ****       }
 469:Core/Src/main.c ****       last_rx_tick = HAL_GetTick();
 470:Core/Src/main.c ****     }
 471:Core/Src/main.c ****     else
 472:Core/Src/main.c ****     {
 473:Core/Src/main.c ****       /* Stop quickly after end of frame once data has started to arrive. */
 474:Core/Src/main.c ****       if ((response_len > 0U) && ((HAL_GetTick() - last_rx_tick) > 120U))
 475:Core/Src/main.c ****       {
 476:Core/Src/main.c ****         break;
 477:Core/Src/main.c ****       }
 478:Core/Src/main.c ****     }
 479:Core/Src/main.c ****   }
 480:Core/Src/main.c **** 
 481:Core/Src/main.c ****   response[response_len] = '\0';
 482:Core/Src/main.c **** 
 483:Core/Src/main.c ****   if (response_len > 0U)
 484:Core/Src/main.c ****   {
 485:Core/Src/main.c ****     printf("LoRa response to %s: %s", label, response);
 486:Core/Src/main.c ****     if (response[response_len - 1U] != '\n')
 487:Core/Src/main.c ****     {
 488:Core/Src/main.c ****       printf("\n\r");
 489:Core/Src/main.c ****     }
 490:Core/Src/main.c ****   }
 491:Core/Src/main.c ****   else
 492:Core/Src/main.c ****   {
 493:Core/Src/main.c ****     printf("LoRa response to %s: (no response)\n\r", label);
 494:Core/Src/main.c ****   }
 495:Core/Src/main.c **** 
 496:Core/Src/main.c ****   HAL_Delay(post_cmd_delay_ms);
