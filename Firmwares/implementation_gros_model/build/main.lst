 436:Core/Src/main.c **** static void SleepForMs(uint32_t delay_ms)
 437:Core/Src/main.c **** {
 438:Core/Src/main.c ****   const uint32_t start = HAL_GetTick();
 439:Core/Src/main.c **** 
 440:Core/Src/main.c ****   while ((HAL_GetTick() - start) < delay_ms)
 441:Core/Src/main.c ****   {
 442:Core/Src/main.c ****     /* Enter Sleep mode until next interrupt (SysTick or external IRQ). */
 443:Core/Src/main.c ****     HAL_PWR_EnterSLEEPMode(PWR_MAINREGULATOR_ON, PWR_SLEEPENTRY_WFI);
 444:Core/Src/main.c ****   }
