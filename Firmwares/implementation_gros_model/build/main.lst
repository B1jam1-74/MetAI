 155:Core/Src/main.c **** 
 156:Core/Src/main.c ****   /* USER CODE END BSP */
 157:Core/Src/main.c **** 
 158:Core/Src/main.c ****   /* Infinite loop */
 159:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 160:Core/Src/main.c **** 
 161:Core/Src/main.c ****   // Connexion à la gateway Lora
 162:Core/Src/main.c ****   LoRa_SendATAndPrintResponse("AT", (const uint8_t *)"AT\r\n", sizeof("AT\r\n") - 1U, 500U, 1000U);
 163:Core/Src/main.c ****   LoRa_SendATAndPrintResponse("AT+MODE=LWOTAA", (const uint8_t *)"AT+MODE=LWOTAA\r\n",
 164:Core/Src/main.c ****                               sizeof("AT+MODE=LWOTAA\r\n") - 1U, 700U, 1000U);
 165:Core/Src/main.c ****   LoRa_SendATAndPrintResponse("AT+JOIN", (const uint8_t *)"AT+JOIN\r\n",
 166:Core/Src/main.c ****                               sizeof("AT+JOIN\r\n") - 1U, 2000U, 5000U);
 167:Core/Src/main.c **** 
 168:Core/Src/main.c ****   while (1)
 169:Core/Src/main.c ****   {
 170:Core/Src/main.c **** 
 171:Core/Src/main.c ****     /* USER CODE END WHILE */
 172:Core/Src/main.c **** 
 173:Core/Src/main.c ****   MX_X_CUBE_AI_Process();
 174:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 175:Core/Src/main.c **** 
 176:Core/Src/main.c ****     // Variables pour stocker les données des capteurs + la classe prédite par le modèle AI
 177:Core/Src/main.c ****     float_t pressure_hpa = 0.0f;
 178:Core/Src/main.c ****     float_t pressure_temperature_deg_c = 0.0f;
 179:Core/Src/main.c ****     float_t humidity_perc = 0.0f;
 180:Core/Src/main.c ****     float_t humidity_temperature_deg_c = 0.0f;
 181:Core/Src/main.c ****     char lora_cmd[96];
 182:Core/Src/main.c ****     int lora_cmd_len = 0;
 183:Core/Src/main.c ****     int32_t predicted_class = -1;
 184:Core/Src/main.c **** 
 185:Core/Src/main.c ****     // Reveil du module Lora pour l'envoi des données
 186:Core/Src/main.c ****     LoRa_SendATAndPrintResponse("AT(wake)", (const uint8_t *)LORA_WAKE_CMD,
 187:Core/Src/main.c ****                   sizeof(LORA_WAKE_CMD) - 1U, 500U, 300U);
 188:Core/Src/main.c **** 
 189:Core/Src/main.c ****     // Lecture des données des capteurs 
 190:Core/Src/main.c ****     lps22hh_read_data_polling(&pressure_hpa, &pressure_temperature_deg_c);
 191:Core/Src/main.c ****     hts221_read_data_polling(&humidity_perc, &humidity_temperature_deg_c);
 192:Core/Src/main.c **** 
 193:Core/Src/main.c ****     // Récupération de la classe prédite par le modèle AI
 194:Core/Src/main.c ****     predicted_class = MX_X_CUBE_AI_GetLastPredictedClass();
 195:Core/Src/main.c **** 
 196:Core/Src/main.c ****     // Formatage de la payload à envoyer (ex: AT+MSG="P=1013.25,H=45.00,T=22.50,C=0")
 197:Core/Src/main.c ****     lora_cmd_len = snprintf(lora_cmd, sizeof(lora_cmd),
 198:Core/Src/main.c ****                 "AT+MSG=\"P=%.2f,H=%.2f,T=%.2f,C=%ld\"\r\n",
 199:Core/Src/main.c ****                             (double)pressure_hpa,
 200:Core/Src/main.c ****                             (double)humidity_perc,
 201:Core/Src/main.c ****                 (double)pressure_temperature_deg_c,
ARM GAS  /tmp/ccfoQJXi.s 			page 5


 202:Core/Src/main.c ****                 (long)predicted_class);
 203:Core/Src/main.c ****     if ((lora_cmd_len > 0) && ((size_t)lora_cmd_len < sizeof(lora_cmd)))
 204:Core/Src/main.c ****     {
 205:Core/Src/main.c ****       LoRa_SendATAndPrintResponse("AT+MSG(sensor)", (const uint8_t *)lora_cmd,
 206:Core/Src/main.c ****                                   (uint16_t)lora_cmd_len, 3000U, 1000U);
 207:Core/Src/main.c ****     }
 208:Core/Src/main.c ****     else
 209:Core/Src/main.c ****     { 
 210:Core/Src/main.c ****       printf("LoRa payload format error\n\r");
 211:Core/Src/main.c ****     }
 212:Core/Src/main.c **** 
