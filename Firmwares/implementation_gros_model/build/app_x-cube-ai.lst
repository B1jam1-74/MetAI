 208:X-CUBE-AI/App/app_x-cube-ai.c **** static void print_fixed_2(const char* label, float value, const char* unit)
 209:X-CUBE-AI/App/app_x-cube-ai.c **** {
 210:X-CUBE-AI/App/app_x-cube-ai.c ****   int32_t scaled = (int32_t)(value * 100.0f);
 211:X-CUBE-AI/App/app_x-cube-ai.c ****   int32_t sign = 1;
 212:X-CUBE-AI/App/app_x-cube-ai.c ****   int32_t whole;
 213:X-CUBE-AI/App/app_x-cube-ai.c ****   int32_t frac;
 214:X-CUBE-AI/App/app_x-cube-ai.c **** 
 215:X-CUBE-AI/App/app_x-cube-ai.c ****   if (scaled < 0) {
 216:X-CUBE-AI/App/app_x-cube-ai.c ****     sign = -1;
 217:X-CUBE-AI/App/app_x-cube-ai.c ****     scaled = -scaled;
 218:X-CUBE-AI/App/app_x-cube-ai.c ****   }
 219:X-CUBE-AI/App/app_x-cube-ai.c **** 
 220:X-CUBE-AI/App/app_x-cube-ai.c ****   whole = scaled / 100;
 221:X-CUBE-AI/App/app_x-cube-ai.c ****   frac = scaled % 100;
 222:X-CUBE-AI/App/app_x-cube-ai.c **** 
 223:X-CUBE-AI/App/app_x-cube-ai.c ****   if (sign < 0) {
 224:X-CUBE-AI/App/app_x-cube-ai.c ****     printf("%s-%ld.%02ld%s", label, (long)whole, (long)frac, unit);
 225:X-CUBE-AI/App/app_x-cube-ai.c ****   } else {
 226:X-CUBE-AI/App/app_x-cube-ai.c ****     printf("%s%ld.%02ld%s", label, (long)whole, (long)frac, unit);
 227:X-CUBE-AI/App/app_x-cube-ai.c ****   }
 228:X-CUBE-AI/App/app_x-cube-ai.c **** }
