 132:Core/Src/hts221_read_data_polling.c **** /*
 133:Core/Src/hts221_read_data_polling.c ****  *  Function used to apply coefficient
 134:Core/Src/hts221_read_data_polling.c ****  */
 135:Core/Src/hts221_read_data_polling.c **** typedef struct {
 136:Core/Src/hts221_read_data_polling.c ****   float_t x0;
 137:Core/Src/hts221_read_data_polling.c ****   float_t y0;
 138:Core/Src/hts221_read_data_polling.c ****   float_t x1;
 139:Core/Src/hts221_read_data_polling.c ****   float_t y1;
 140:Core/Src/hts221_read_data_polling.c **** } lin_t;
 141:Core/Src/hts221_read_data_polling.c **** 
 142:Core/Src/hts221_read_data_polling.c **** float_t linear_interpolation(lin_t *lin, int16_t x)
 143:Core/Src/hts221_read_data_polling.c **** {
ARM GAS  /tmp/ccQbP6VS.s 			page 4


 144:Core/Src/hts221_read_data_polling.c ****   return ((lin->y1 - lin->y0) * x + ((lin->x1 * lin->y0) -
 145:Core/Src/hts221_read_data_polling.c ****                                      (lin->x0 * lin->y1)))
 146:Core/Src/hts221_read_data_polling.c ****          / (lin->x1 - lin->x0);
 147:Core/Src/hts221_read_data_polling.c **** }
 148:Core/Src/hts221_read_data_polling.c **** void hts221_read_data_polling(float_t *humidity_out, float_t *temperature_out)
 149:Core/Src/hts221_read_data_polling.c **** {
 150:Core/Src/hts221_read_data_polling.c ****   if ((humidity_out == NULL) || (temperature_out == NULL)) {
 151:Core/Src/hts221_read_data_polling.c ****     return;
 152:Core/Src/hts221_read_data_polling.c ****   }
 153:Core/Src/hts221_read_data_polling.c **** 
 154:Core/Src/hts221_read_data_polling.c ****   /* Initialize platform specific hardware */
 155:Core/Src/hts221_read_data_polling.c ****   platform_init();
 156:Core/Src/hts221_read_data_polling.c ****   /* Initialize mems driver interface */
 157:Core/Src/hts221_read_data_polling.c ****   stmdev_ctx_t dev_ctx;
 158:Core/Src/hts221_read_data_polling.c ****   dev_ctx.write_reg = platform_write;
 159:Core/Src/hts221_read_data_polling.c ****   dev_ctx.read_reg = platform_read;
 160:Core/Src/hts221_read_data_polling.c ****   dev_ctx.mdelay = platform_delay;
 161:Core/Src/hts221_read_data_polling.c ****   dev_ctx.handle = &SENSOR_BUS;
 162:Core/Src/hts221_read_data_polling.c ****   /* Check device ID */
 163:Core/Src/hts221_read_data_polling.c ****   whoamI = 0;
 164:Core/Src/hts221_read_data_polling.c ****   hts221_device_id_get(&dev_ctx, &whoamI);
 165:Core/Src/hts221_read_data_polling.c **** 
 166:Core/Src/hts221_read_data_polling.c ****   if (whoamI != HTS221_ID) {
 167:Core/Src/hts221_read_data_polling.c ****     *humidity_out = 0.0f;
 168:Core/Src/hts221_read_data_polling.c ****     *temperature_out = 0.0f;
 169:Core/Src/hts221_read_data_polling.c ****     printf("HTS221 not found\r\n");
 170:Core/Src/hts221_read_data_polling.c ****     return;
 171:Core/Src/hts221_read_data_polling.c ****   }
 172:Core/Src/hts221_read_data_polling.c **** 
 173:Core/Src/hts221_read_data_polling.c ****   /* Read humidity calibration coefficient */
 174:Core/Src/hts221_read_data_polling.c ****   lin_t lin_hum;
 175:Core/Src/hts221_read_data_polling.c ****   hts221_hum_adc_point_0_get(&dev_ctx, &lin_hum.x0);
 176:Core/Src/hts221_read_data_polling.c ****   hts221_hum_rh_point_0_get(&dev_ctx, &lin_hum.y0);
 177:Core/Src/hts221_read_data_polling.c ****   hts221_hum_adc_point_1_get(&dev_ctx, &lin_hum.x1);
 178:Core/Src/hts221_read_data_polling.c ****   hts221_hum_rh_point_1_get(&dev_ctx, &lin_hum.y1);
 179:Core/Src/hts221_read_data_polling.c ****   /* Read temperature calibration coefficient */
 180:Core/Src/hts221_read_data_polling.c ****   lin_t lin_temp;
 181:Core/Src/hts221_read_data_polling.c ****   hts221_temp_adc_point_0_get(&dev_ctx, &lin_temp.x0);
 182:Core/Src/hts221_read_data_polling.c ****   hts221_temp_deg_point_0_get(&dev_ctx, &lin_temp.y0);
 183:Core/Src/hts221_read_data_polling.c ****   hts221_temp_adc_point_1_get(&dev_ctx, &lin_temp.x1);
 184:Core/Src/hts221_read_data_polling.c ****   hts221_temp_deg_point_1_get(&dev_ctx, &lin_temp.y1);
 185:Core/Src/hts221_read_data_polling.c ****   /* Enable Block Data Update */
 186:Core/Src/hts221_read_data_polling.c ****   hts221_block_data_update_set(&dev_ctx, PROPERTY_ENABLE);
 187:Core/Src/hts221_read_data_polling.c ****   /* Set Output Data Rate */
 188:Core/Src/hts221_read_data_polling.c ****   hts221_data_rate_set(&dev_ctx, HTS221_ODR_1Hz);
 189:Core/Src/hts221_read_data_polling.c ****   /* Device power on */
 190:Core/Src/hts221_read_data_polling.c ****   hts221_power_on_set(&dev_ctx, PROPERTY_ENABLE);
 191:Core/Src/hts221_read_data_polling.c **** 
 192:Core/Src/hts221_read_data_polling.c ****   /* Wait until both humidity and temperature data are available */
 193:Core/Src/hts221_read_data_polling.c ****   hts221_status_reg_t status;
 194:Core/Src/hts221_read_data_polling.c ****   do {
 195:Core/Src/hts221_read_data_polling.c ****     hts221_status_get(&dev_ctx, &status);
 196:Core/Src/hts221_read_data_polling.c ****   } while (!status.h_da || !status.t_da);  // wait until both are ready
 197:Core/Src/hts221_read_data_polling.c **** 
 198:Core/Src/hts221_read_data_polling.c ****   /* Read humidity data */
 199:Core/Src/hts221_read_data_polling.c ****   memset(&data_raw_humidity, 0x00, sizeof(int16_t));
 200:Core/Src/hts221_read_data_polling.c ****   hts221_humidity_raw_get(&dev_ctx, &data_raw_humidity);
ARM GAS  /tmp/ccQbP6VS.s 			page 5


 201:Core/Src/hts221_read_data_polling.c ****   humidity_perc = linear_interpolation(&lin_hum, data_raw_humidity);
 202:Core/Src/hts221_read_data_polling.c **** 
 203:Core/Src/hts221_read_data_polling.c ****   if (humidity_perc < 0)   humidity_perc = 0;
 204:Core/Src/hts221_read_data_polling.c ****   if (humidity_perc > 100) humidity_perc = 100;
 205:Core/Src/hts221_read_data_polling.c **** 
 206:Core/Src/hts221_read_data_polling.c ****   *humidity_out = humidity_perc;
 207:Core/Src/hts221_read_data_polling.c **** 
 208:Core/Src/hts221_read_data_polling.c ****   printf("Humidity [%%]:%3.2f\r\n", humidity_perc);
 209:Core/Src/hts221_read_data_polling.c **** 
 210:Core/Src/hts221_read_data_polling.c ****   /* Read temperature data */
 211:Core/Src/hts221_read_data_polling.c ****   memset(&data_raw_temperature, 0x00, sizeof(int16_t));
 212:Core/Src/hts221_read_data_polling.c ****   hts221_temperature_raw_get(&dev_ctx, &data_raw_temperature);
 213:Core/Src/hts221_read_data_polling.c ****   temperature_degC = linear_interpolation(&lin_temp, data_raw_temperature);
 214:Core/Src/hts221_read_data_polling.c ****   *temperature_out = temperature_degC;
 215:Core/Src/hts221_read_data_polling.c ****   printf("Temperature [degC]:%6.2f\r\n", temperature_degC);
 216:Core/Src/hts221_read_data_polling.c **** }
