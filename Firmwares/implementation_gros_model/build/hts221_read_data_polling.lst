 218:Core/Src/hts221_read_data_polling.c **** /*
 219:Core/Src/hts221_read_data_polling.c ****  * @brief  Write generic device register (platform dependent)
 220:Core/Src/hts221_read_data_polling.c ****  *
 221:Core/Src/hts221_read_data_polling.c ****  * @param  handle    customizable argument. In this examples is used in
 222:Core/Src/hts221_read_data_polling.c ****  *                   order to select the correct sensor bus handler.
 223:Core/Src/hts221_read_data_polling.c ****  * @param  reg       register to write
 224:Core/Src/hts221_read_data_polling.c ****  * @param  bufp      pointer to data to write in register reg
 225:Core/Src/hts221_read_data_polling.c ****  * @param  len       number of consecutive register to write
 226:Core/Src/hts221_read_data_polling.c ****  *
 227:Core/Src/hts221_read_data_polling.c ****  */
 228:Core/Src/hts221_read_data_polling.c **** static int32_t platform_write(void *handle, uint8_t reg, const uint8_t *bufp,
 229:Core/Src/hts221_read_data_polling.c ****                               uint16_t len)
 230:Core/Src/hts221_read_data_polling.c **** {
 231:Core/Src/hts221_read_data_polling.c **** 
 232:Core/Src/hts221_read_data_polling.c ****   /* Write multiple command */
 233:Core/Src/hts221_read_data_polling.c ****   reg |= 0x80;
 234:Core/Src/hts221_read_data_polling.c ****   HAL_I2C_Mem_Write(handle, HTS221_I2C_ADDRESS, reg,
 235:Core/Src/hts221_read_data_polling.c ****                     I2C_MEMADD_SIZE_8BIT, (uint8_t*) bufp, len, 1000);
 236:Core/Src/hts221_read_data_polling.c **** 
 237:Core/Src/hts221_read_data_polling.c ****   return 0;
 238:Core/Src/hts221_read_data_polling.c **** }
 239:Core/Src/hts221_read_data_polling.c **** 
 240:Core/Src/hts221_read_data_polling.c **** /*
 241:Core/Src/hts221_read_data_polling.c ****  * @brief  Read generic device register (platform dependent)
 242:Core/Src/hts221_read_data_polling.c ****  *
