2340:Drivers/STM32U5xx_HAL_Driver/Src/stm32u5xx_hal_pwr_ex.c **** /**
2341:Drivers/STM32U5xx_HAL_Driver/Src/stm32u5xx_hal_pwr_ex.c ****   * @brief  Enable the flash memory fast wakeup from Stop 0 and Stop 1 modes.
2342:Drivers/STM32U5xx_HAL_Driver/Src/stm32u5xx_hal_pwr_ex.c ****   * @note   This feature is used to obtain the best trade-off between low-power
2343:Drivers/STM32U5xx_HAL_Driver/Src/stm32u5xx_hal_pwr_ex.c ****   *         consumption and wakeup time when exiting the Stop 0 or Stop 1 modes.
2344:Drivers/STM32U5xx_HAL_Driver/Src/stm32u5xx_hal_pwr_ex.c ****   *         When this feature is enabled, the Flash memory remains in normal
2345:Drivers/STM32U5xx_HAL_Driver/Src/stm32u5xx_hal_pwr_ex.c ****   *         mode in Stop 0 and Stop 1 modes, which offers a faster startup time
2346:Drivers/STM32U5xx_HAL_Driver/Src/stm32u5xx_hal_pwr_ex.c ****   *         with higher consumption.
ARM GAS  /tmp/ccuB84o5.s 			page 90


