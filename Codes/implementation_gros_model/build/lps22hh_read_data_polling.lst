 145:Core/Src/lps22hh_read_data_polling.c **** 
 146:Core/Src/lps22hh_read_data_polling.c ****   stmdev_ctx_t dev_ctx;
 147:Core/Src/lps22hh_read_data_polling.c ****   lps22hh_status_t status;
 148:Core/Src/lps22hh_read_data_polling.c ****   dev_ctx.write_reg = platform_write;
 149:Core/Src/lps22hh_read_data_polling.c ****   dev_ctx.read_reg = platform_read;
 150:Core/Src/lps22hh_read_data_polling.c ****   dev_ctx.mdelay = platform_delay;
 151:Core/Src/lps22hh_read_data_polling.c ****   dev_ctx.handle = &SENSOR_BUS;
 152:Core/Src/lps22hh_read_data_polling.c ****   platform_init();
 153:Core/Src/lps22hh_read_data_polling.c ****   platform_delay(BOOT_TIME);
 154:Core/Src/lps22hh_read_data_polling.c **** 
 155:Core/Src/lps22hh_read_data_polling.c ****   whoamI = 0;
 156:Core/Src/lps22hh_read_data_polling.c ****   lps22hh_device_id_get(&dev_ctx, &whoamI);
 157:Core/Src/lps22hh_read_data_polling.c ****   //printf("LPS22HH whoamI=0x%02X\r\n", whoamI);  // should print 0xB3
 158:Core/Src/lps22hh_read_data_polling.c **** 
 159:Core/Src/lps22hh_read_data_polling.c ****   if (whoamI != LPS22HH_ID) {
 160:Core/Src/lps22hh_read_data_polling.c ****     printf("LPS22HH not found\r\n");
 161:Core/Src/lps22hh_read_data_polling.c ****     *pressure_out = 0.0f;
 162:Core/Src/lps22hh_read_data_polling.c ****     *temperature_out = 0.0f;
 163:Core/Src/lps22hh_read_data_polling.c ****     return;  // exit instead of while(1)
 164:Core/Src/lps22hh_read_data_polling.c ****   }
 165:Core/Src/lps22hh_read_data_polling.c **** 
 166:Core/Src/lps22hh_read_data_polling.c ****   /* Restore default configuration */
 167:Core/Src/lps22hh_read_data_polling.c ****   lps22hh_reset_set(&dev_ctx, PROPERTY_ENABLE);
 168:Core/Src/lps22hh_read_data_polling.c ****   do {
 169:Core/Src/lps22hh_read_data_polling.c ****     lps22hh_reset_get(&dev_ctx, &rst);
 170:Core/Src/lps22hh_read_data_polling.c ****   } while (rst);
 171:Core/Src/lps22hh_read_data_polling.c **** 
 172:Core/Src/lps22hh_read_data_polling.c ****   /* Enable Block Data Update */
 173:Core/Src/lps22hh_read_data_polling.c ****   lps22hh_block_data_update_set(&dev_ctx, PROPERTY_ENABLE);
 174:Core/Src/lps22hh_read_data_polling.c ****   /* Set Output Data Rate */
 175:Core/Src/lps22hh_read_data_polling.c ****   lps22hh_data_rate_set(&dev_ctx, LPS22HH_10_Hz_LOW_NOISE);
 176:Core/Src/lps22hh_read_data_polling.c **** 
 177:Core/Src/lps22hh_read_data_polling.c ****   /* Wait until both pressure and temperature are ready */
 178:Core/Src/lps22hh_read_data_polling.c ****   do {
 179:Core/Src/lps22hh_read_data_polling.c ****     lps22hh_read_reg(&dev_ctx, LPS22HH_STATUS, (uint8_t *)&status, 1);
 180:Core/Src/lps22hh_read_data_polling.c ****   } while (!status.p_da || !status.t_da);
 181:Core/Src/lps22hh_read_data_polling.c **** 
 182:Core/Src/lps22hh_read_data_polling.c ****   /* Read pressure */
 183:Core/Src/lps22hh_read_data_polling.c ****   memset(&data_raw_pressure, 0x00, sizeof(uint32_t));
 184:Core/Src/lps22hh_read_data_polling.c ****   lps22hh_pressure_raw_get(&dev_ctx, &data_raw_pressure);
 185:Core/Src/lps22hh_read_data_polling.c ****   pressure_hPa = lps22hh_from_lsb_to_hpa(data_raw_pressure);
 186:Core/Src/lps22hh_read_data_polling.c ****   *pressure_out = pressure_hPa;
 187:Core/Src/lps22hh_read_data_polling.c ****   printf("pressure [hPa]:%6.2f\r\n", pressure_hPa);
 188:Core/Src/lps22hh_read_data_polling.c **** 
 189:Core/Src/lps22hh_read_data_polling.c ****   /* Read temperature */
 190:Core/Src/lps22hh_read_data_polling.c ****   memset(&data_raw_temperature, 0x00, sizeof(int16_t));
 191:Core/Src/lps22hh_read_data_polling.c ****   lps22hh_temperature_raw_get(&dev_ctx, &data_raw_temperature);
 192:Core/Src/lps22hh_read_data_polling.c ****   temperature_degC = lps22hh_from_lsb_to_celsius(data_raw_temperature);
 193:Core/Src/lps22hh_read_data_polling.c ****   *temperature_out = temperature_degC;
 194:Core/Src/lps22hh_read_data_polling.c ****   printf("temperature [degC]:%6.2f\r\n", temperature_degC);
 195:Core/Src/lps22hh_read_data_polling.c **** }
